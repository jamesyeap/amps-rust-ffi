<?xml version="1.0" encoding="UTF-8"?>
<!--
  AMPS Configuration for Integration Testing
  
  This configuration sets up:
  - TCP transport on port 9007 for JSON messages
  - Test topics including a SOW-enabled topic
  - Logging to stdout
-->
<AMPSConfig>
    <Name>TestAMPS</Name>
    
    <Transports>
        <Transport>
            <Name>json-tcp</Name>
            <Type>tcp</Type>
            <InetAddr>9007</InetAddr>
            <MessageType>json</MessageType>
        </Transport>
    </Transports>
    
    <SOW>
        <!-- SOW-enabled topic for SOW query tests -->
        <Topic>
            <FileName>./sow/%n.sow</FileName>
            <Topic>sow-test</Topic>
            <MessageType>json</MessageType>
            <Key>/id</Key>
        </Topic>
    </SOW>
    
    <Logging>
        <Target>
            <Protocol>stdout</Protocol>
            <Level>info</Level>
        </Target>
    </Logging>
    
    <Admin>
        <InetAddr>localhost:9008</InetAddr>
    </Admin>
</AMPSConfig>
