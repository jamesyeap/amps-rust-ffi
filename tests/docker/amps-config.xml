<?xml version="1.0" encoding="UTF-8"?>
<!--
  AMPS Configuration for Integration Testing
  
  This configuration sets up:
  - TCP transport on port 9007 for JSON messages
  - Test topics including a SOW-enabled topic
  - Logging to stdout
-->
<AMPSConfig>
    <Name>TestAMPS</Name>
    
    <Transports>
        <Transport>
            <Name>json-tcp</Name>
            <Type>amps-tcp</Type>
            <InetAddr>9007</InetAddr>
            <MessageType>json</MessageType>
        </Transport>
        <Transport>
            <Name>admin-tcp</Name>
            <Type>amps-tcp</Type>
            <InetAddr>9008</InetAddr>
            <MessageType>amps</MessageType>
        </Transport>
    </Transports>
    
    <Topics>
        <!-- Standard topic for publish/subscribe testing -->
        <Topic>
            <Name>test-topic</Name>
            <MessageType>json</MessageType>
        </Topic>
        
        <!-- Topic for subscription tests -->
        <Topic>
            <Name>subscription-test</Name>
            <MessageType>json</MessageType>
        </Topic>
        
        <!-- SOW-enabled topic for SOW query tests -->
        <Topic>
            <Name>sow-test</Name>
            <MessageType>json</MessageType>
            <Persistence>
                <Protocol>json</Protocol>
                <Key>/id</Key>
            </Persistence>
        </Topic>
        
        <!-- Topic for exception handling tests -->
        <Topic>
            <Name>error-test</Name>
            <MessageType>json</MessageType>
        </Topic>
    </Topics>
    
    <Logging>
        <Target>
            <Protocol>stdout</Protocol>
            <Level>info</Level>
        </Target>
    </Logging>
    
    <Admin>
        <InetAddr>9008</InetAddr>
    </Admin>
</AMPSConfig>
